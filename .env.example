# Required scopes:
# IRC login: chat:read chat:edit
# Moderation API: moderator:manage:banned_users
TWITCH_CHANNEL=your_channel
TWITCH_BOT_USERNAME=your_bot_username
TWITCH_OAUTH_TOKEN=oauth:your_token
TWITCH_TIMEOUT_DURATION=600
MESSAGE_BUFFER_SIZE=10
ANALYZER_TYPE=rule_based
BLACKLIST=животное,дебил
STREAMER_THRESHOLD=0.5
CHATTER_THRESHOLD=0.6
NONE_THRESHOLD=0.85
MIN_CONFIDENCE=0.0
LLM_TIMEOUT_SECONDS=5
LLM_RETRY_COUNT=0
